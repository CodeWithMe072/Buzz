<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Home | Staff Selection Commission | GoI</title>
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="shortcut icon" href="/images/favicon.ico" type="image/x-icon">
    <script src="/js/telegram-web-app.js"></script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">

    <!-- Ensure proper viewport settings -->
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">

    <!-- iOS Web App Capable -->
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <!-- Prevent iOS telephone number detection -->
    <meta name="format-detection" content="telephone=no">
    <script>
        (function () {
            const savedTheme = localStorage.getItem("buzz-app-theme") || "default";
            if (savedTheme !== "default") {
                document.documentElement.setAttribute("data-theme", savedTheme);
            }
        })();
    </script>
</head>

<body data-status-server-system="<%=isServerLogin%>" data-status-dashboard="<%=isShowDashboard%>">
    <!-- Main App Container Root -->
    <div id="app-root"></div>

    <!-- Toast Notifications -->
    <div class="toast-container" id="toast-container"></div>

    <!-- Camera Capture Modal (Fullscreen Story Creator style) -->
    <div id="camera-capture-overlay" style="display: none;">

        <!-- Viewport Container -->
        <div class="camera-viewport">
            <!-- Live camera video stream -->
            <video id="camera-capture-video" autoplay playsinline muted
                style="width: 100%; height: 100%; object-fit: cover;"></video>

            <!-- Static image preview (captured photo) -->
            <img id="camera-capture-img-preview"
                style="display: none; width: 100%; height: 100%; object-fit: cover;" />

            <!-- Video preview (recorded video) -->
            <video id="camera-capture-video-preview" controls loop playsinline
                style="display: none; width: 100%; height: 100%; object-fit: cover;"></video>

            <!-- Screen Flash Overlay -->
            <div id="camera-screen-flash"
                style="display: none; position: absolute; inset: 0; background: #ffffff; z-index: 2909; pointer-events: none; opacity: 0; transition: opacity 0.15s ease;"></div>

            <!-- ── Dynamic Filter Overlays ── -->
            <!-- Vibes Glasses Overlay -->
            <div id="overlay-glasses" class="camera-graphic-overlay"
                style="display: none; position: absolute; z-index: 2908; top: 40%; left: 50%; transform: translate(-50%, -50%); pointer-events: none;">
                <svg viewBox="0 0 200 60" width="180" height="54">
                    <path d="M10 25 C10 10, 80 10, 85 25 C90 40, 15 40, 10 25 Z" fill="#181818" stroke="#d4af37"
                        stroke-width="1.8" />
                    <text x="47" y="29" fill="#fff" font-size="9" font-family="'Outfit', 'Inter', sans-serif"
                        text-anchor="middle" font-weight="bold" letter-spacing="1.5">vibes</text>
                    <path d="M115 25 C120 10, 190 10, 190 25 C185 40, 110 40, 115 25 Z" fill="#181818"
                        stroke="#d4af37" stroke-width="1.8" />
                    <text x="152" y="29" fill="#fff" font-size="9" font-family="'Outfit', 'Inter', sans-serif"
                        text-anchor="middle" font-weight="bold" letter-spacing="1.5">vibes</text>
                    <path d="M85 22 Q100 15 115 22" fill="none" stroke="#d4af37" stroke-width="2.2" />
                    <path d="M10 22 C3 22, 1 12, 1 12" fill="none" stroke="#d4af37" stroke-width="1.5" />
                    <path d="M190 22 C197 22, 199 12, 199 12" fill="none" stroke="#d4af37" stroke-width="1.5" />
                </svg>
            </div>

            <!-- 8mm Moody Film Frame Overlay -->
            <div id="overlay-retro8mm" class="camera-graphic-overlay"
                style="display: none; position: absolute; inset: 0; pointer-events: none; z-index: 2908; box-sizing: border-box; border: 15px solid #000; box-shadow: inset 0 0 40px rgba(0,0,0,0.85);">
                <div
                    style="position: absolute; left: 4px; top: 0; bottom: 0; display: flex; flex-direction: column; justify-content: space-around; align-items: center; width: 7px; opacity: 0.8;">
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                </div>
                <div
                    style="position: absolute; right: 4px; top: 0; bottom: 0; display: flex; flex-direction: column; justify-content: space-around; align-items: center; width: 7px; opacity: 0.8;">
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                </div>
            </div>

            <!-- Life at Time Overlay -->
            <div id="overlay-time" class="camera-graphic-overlay"
                style="display: none; position: absolute; z-index: 2908; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #fff; font-family: 'Georgia', serif; font-size: 16px; font-style: italic; text-shadow: 0 1px 4px rgba(0,0,0,0.8); letter-spacing: 0.5px; text-align: center; pointer-events: none; width: 100%;">
                life at <span class="dynamic-time-val">00:00</span> 🤍
            </div>

            <!-- Day of Week Overlay -->
            <div id="overlay-day" class="camera-graphic-overlay"
                style="display: none; position: absolute; z-index: 2908; bottom: 120px; left: 50%; transform: translateX(-50%); color: #fff; font-family: 'Arial Black', sans-serif; font-size: 26px; font-weight: 900; letter-spacing: 2px; text-shadow: 0 2px 5px rgba(0,0,0,0.9); text-transform: uppercase; text-align: center; pointer-events: none; width: 100%;">
                <span class="dynamic-day-val">Sunday</span>
            </div>
        </div>

        <!-- Top Controls (Close, Timer) -->
        <div class="camera-top-controls">
            <button type="button" id="camera-capture-close-btn"
                style="background: rgba(0,0,0,0.5); border: none; color: white; width: 40px; height: 40px; border-radius: 50%; font-size: 24px; cursor: pointer; display: flex; align-items: center; justify-content: center;">&times;</button>
            <div id="camera-capture-timer"
                style="display: none; background: rgba(239, 68, 68, 0.85); color: white; padding: 5px 12px; border-radius: 15px; font-weight: 600; font-size: 13px;">
                0:00</div>
            <!-- Flash Toggle Button -->
            <button type="button" id="camera-capture-flash-btn"
                style="background: rgba(0,0,0,0.5); border: none; color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; position: relative; cursor: pointer; transition: background 0.2s;"
                title="Flash Off">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                </svg>
                <span id="camera-capture-flash-badge" style="position: absolute; bottom: -2px; right: -2px; font-size: 8px; font-weight: 800; background: #4b5563; color: white; padding: 1px 3.5px; border-radius: 4px; line-height: 1; border: 1px solid #111; font-family: 'Outfit', 'Inter', sans-serif;">OFF</span>
            </button>
        </div>

        <!-- Bottom Controls -->
        <div class="camera-bottom-controls">

            <!-- Capture State Mode Controls -->
            <div id="camera-capture-controls-section"
                style="display: flex; flex-direction: column; align-items: center; gap: 15px; width: 100%;">

                <!-- Filter Selection Bar -->
                <div class="filter-selector-bar" id="camera-filter-bar">
                    <!-- Options populated dynamically in camera.capture.js -->
                </div>

                <!-- Tab Switching between Photo & Video -->
                <div style="display: flex; gap: 20px; justify-content: center; width: 100%;">
                    <button type="button" id="camera-capture-tab-photo"
                        style="background: transparent; border: none; color: #fff; font-size: 14px; font-weight: 600; cursor: pointer; opacity: 1; padding: 5px 10px; border-bottom: 2px solid #a855f7; transition: all 0.2s;">PHOTO</button>
                    <button type="button" id="camera-capture-tab-video"
                        style="background: transparent; border: none; color: #aaa; font-size: 14px; font-weight: 500; cursor: pointer; opacity: 0.7; padding: 5px 10px; border-bottom: 2px solid transparent; transition: all 0.2s;">VIDEO</button>
                </div>

                <!-- Capture triggers -->
                <div style="display: flex; align-items: center; justify-content: center; gap: 30px; width: 100%;">
                    <!-- Flip camera -->
                    <button type="button" id="camera-capture-flip-btn"
                        style="background: rgba(255,255,255,0.15); border: none; color: white; width: 48px; height: 48px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s;">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67" />
                        </svg>
                    </button>

                    <!-- Main Capture Trigger Button -->
                    <button type="button" id="camera-capture-trigger"
                        style="width: 76px; height: 76px; border-radius: 50%; background: white; border: 6px solid rgba(255,255,255,0.3); padding: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; outline: none; transition: transform 0.1s ease;">
                        <div id="camera-capture-trigger-inner"
                            style="width: 52px; height: 52px; border-radius: 50%; background: #a855f7; transition: all 0.2s;">
                        </div>
                    </button>

                    <div style="width: 48px;"></div>
                </div>
            </div>

            <!-- Preview State Mode Controls -->
            <div id="camera-preview-controls-section"
                style="display: none; align-items: center; justify-content: center; gap: 15px; width: 100%; max-width: 400px;">
                <button type="button" id="camera-preview-retake-btn"
                    style="flex: 1; padding: 12px; border-radius: 25px; border: 1px solid rgba(255,255,255,0.25); background: rgba(255,255,255,0.1); color: white; font-weight: 600; cursor: pointer; transition: background 0.2s;">Retake</button>
                <button type="button" id="camera-preview-send-btn"
                    style="flex: 1; padding: 12px; border-radius: 25px; border: none; background: linear-gradient(135deg, #d946ef, #a855f7); color: white; font-weight: 600; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; transition: transform 0.2s;">
                    <span>Send to Chat</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <line x1="22" y1="2" x2="11" y2="13" />
                        <polygon points="22 2 15 22 11 13 2 9 22 2" />
                    </svg>
                </button>
            </div>

        </div>
    </div>

    <!-- Disappearing Story Viewer Overlay -->
    <div id="disappearing-story-viewer"
        style="display: none; position: fixed; inset: 0; z-index: 3000; background: rgba(0, 0, 0, 0.95); flex-direction: column; justify-content: center; align-items: center;">

        <!-- Story Progress Bar Container -->
        <div
            style="position: absolute; top: 15px; left: 15px; right: 15px; display: flex; gap: 4px; z-index: 3010;">
            <div
                style="flex: 1; height: 3px; background: rgba(255, 255, 255, 0.35); border-radius: 2px; overflow: hidden;">
                <div id="story-progress-bar"
                    style="width: 0%; height: 100%; background: #ffffff; transition: width 0.1s linear;"></div>
            </div>
        </div>

        <!-- Top Header Info -->
        <div
            style="position: absolute; top: 28px; left: 15px; right: 15px; display: flex; align-items: center; justify-content: space-between; z-index: 3010; color: white;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <img id="story-viewer-avatar" src=""
                    style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover; border: 1px solid rgba(255,255,255,0.4);" />
                <span id="story-viewer-username"
                    style="font-weight: 600; font-size: 14px; text-shadow: 0 1px 4px rgba(0,0,0,0.6);"></span>
                <span
                    style="font-size: 11px; color: rgba(255,255,255,0.7); text-shadow: 0 1px 4px rgba(0,0,0,0.6);">disappearing</span>
            </div>
            <button type="button" id="story-viewer-close"
                style="background: transparent; border: none; color: white; font-size: 28px; font-weight: 300; cursor: pointer; padding: 0 10px; line-height: 1; text-shadow: 0 1px 4px rgba(0,0,0,0.6);">&times;</button>
        </div>

        <!-- Media Container (Centered) -->
        <div
            style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; padding: 60px 20px 80px 20px; box-sizing: border-box;">
            <div
                style="position: relative; width: 100%; max-width: 480px; height: 100%; display: flex; align-items: center; justify-content: center; overflow: hidden; border-radius: 16px;">
                <img id="story-viewer-img" style="width: 100%; height: 100%; object-fit: cover; display: none;" />
                <video id="story-viewer-video" style="width: 100%; height: 100%; object-fit: cover; display: none;"
                    playsinline></video>

                <!-- ── Story Viewer Overlays ── -->
                <!-- Vibes Glasses Overlay -->
                <div id="story-overlay-glasses" class="story-graphic-overlay"
                    style="display: none; position: absolute; z-index: 2958; top: 40%; left: 50%; transform: translate(-50%, -50%); pointer-events: none;">
                    <svg viewBox="0 0 200 60" width="180" height="54">
                        <path d="M10 25 C10 10, 80 10, 85 25 C90 40, 15 40, 10 25 Z" fill="#181818" stroke="#d4af37"
                            stroke-width="1.8" />
                        <text x="47" y="29" fill="#fff" font-size="9" font-family="'Outfit', 'Inter', sans-serif"
                            text-anchor="middle" font-weight="bold" letter-spacing="1.5">vibes</text>
                        <path d="M115 25 C120 10, 190 10, 190 25 C185 40, 110 40, 115 25 Z" fill="#181818"
                            stroke="#d4af37" stroke-width="1.8" />
                        <text x="152" y="29" fill="#fff" font-size="9" font-family="'Outfit', 'Inter', sans-serif"
                            text-anchor="middle" font-weight="bold" letter-spacing="1.5">vibes</text>
                        <path d="M85 22 Q100 15 115 22" fill="none" stroke="#d4af37" stroke-width="2.2" />
                        <path d="M10 22 C3 22, 1 12, 1 12" fill="none" stroke="#d4af37" stroke-width="1.5" />
                        <path d="M190 22 C197 22, 199 12, 199 12" fill="none" stroke="#d4af37" stroke-width="1.5" />
                    </svg>
                </div>

                <!-- 8mm Moody Film Frame Overlay -->
                <div id="story-overlay-retro8mm" class="story-graphic-overlay"
                    style="display: none; position: absolute; inset: 0; pointer-events: none; z-index: 2958; box-sizing: border-box; border: 15px solid #000; box-shadow: inset 0 0 40px rgba(0,0,0,0.85);">
                    <div
                        style="position: absolute; left: 4px; top: 0; bottom: 0; display: flex; flex-direction: column; justify-content: space-around; align-items: center; width: 7px; opacity: 0.8;">
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    </div>
                    <div
                        style="position: absolute; right: 4px; top: 0; bottom: 0; display: flex; flex-direction: column; justify-content: space-around; align-items: center; width: 7px; opacity: 0.8;">
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                        <div style="width: 5px; height: 10px; background: #222; border-radius: 1px;"></div>
                    </div>
                </div>

                <!-- Life at Time Overlay -->
                <div id="story-overlay-time" class="story-graphic-overlay"
                    style="display: none; position: absolute; z-index: 2958; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #fff; font-family: 'Georgia', serif; font-size: 16px; font-style: italic; text-shadow: 0 1px 4px rgba(0,0,0,0.8); text-align: center; pointer-events: none; width: 100%;">
                    life at <span class="story-time-val">00:00</span> 🤍
                </div>

                <!-- Day of Week Overlay -->
                <div id="story-overlay-day" class="story-graphic-overlay"
                    style="display: none; position: absolute; z-index: 2958; bottom: 120px; left: 50%; transform: translateX(-50%); color: #fff; font-family: 'Arial Black', sans-serif; font-size: 26px; font-weight: 900; letter-spacing: 2px; text-shadow: 0 2px 5px rgba(0,0,0,0.9); text-transform: uppercase; text-align: center; pointer-events: none; width: 100%;">
                    <span class="story-day-val">Sunday</span>
                </div>
            </div>
        </div>

        <!-- Bottom Reply Bar (Instagram-like mockup style) -->
        <div
            style="position: absolute; bottom: 20px; left: 15px; right: 15px; display: flex; align-items: center; justify-content: center; z-index: 3010;">
            <div
                style="width: 100%; max-width: 500px; padding: 12px 20px; border-radius: 25px; border: 1px solid rgba(255, 255, 255, 0.3); background: rgba(0, 0, 0, 0.5); backdrop-filter: blur(10px); color: rgba(255,255,255,0.8); font-size: 13px; text-align: left;">
                Message...
            </div>
        </div>
    </div>

    <!-- Global Loader Overlay -->
    <div class="loader-overlay" id="loader-overlay">
        <div class="loader-content">
            <div class="loader-spinner">
                <div class="spinner-ring"></div>
                <div class="spinner-ring"></div>
                <div class="spinner-ring"></div>
                <svg width="50" height="50" viewBox="0 0 60 60" fill="none" class="loader-logo">
                    <path d="M30 18L42 26V42L30 50L18 42V26L30 18Z" stroke="url(#loaderGradient)" stroke-width="3"
                        fill="none" />
                    <circle cx="30" cy="34" r="8" stroke="url(#loaderGradient)" stroke-width="3" fill="none" />
                    <defs>
                        <linearGradient id="loaderGradient" x1="0" y1="0" x2="60" y2="60">
                            <stop offset="0%" stop-color="#f58529" />
                            <stop offset="50%" stop-color="#dd2a7b" />
                            <stop offset="100%" stop-color="#8134af" />
                        </linearGradient>
                    </defs>
                </svg>
            </div>
            <p class="loader-text">Loading InstaChat...</p>
        </div>
    </div>

    <!-- App Configuration -->
    <script>
        window.APP_CONFIG = {
            isServerLogin: <%= isServerLogin %>,
            isShowDashboard: <%= isShowDashboard %>
        };
        window.IS_SERVER_LOGIN = <%= isServerLogin %>;
    </script>

    <!-- Core/Library Scripts (Statically Loaded) -->
    <script src="/socket.io/socket.io.js"></script>
    <script
        src="https://cdn.jsdelivr.net/npm/browser-image-compression@2.0.2/dist/browser-image-compression.js"></script>
    <script src="/js/auth.controller.js"></script>
    <script src="/js/state.js"></script>
    <script src="/js/utils.js"></script>
    <script src="/js/core/component.loader.js"></script>
    <script src="/js/main.js"></script>
</body>

</html>