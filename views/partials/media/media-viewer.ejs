<div class="media-viewer-overlay" id="mediaViewer">
    <div class="viewer-header">
        <div class="viewer-info">
            <span class="sender-name"></span>
            <span class="media-counter">
                <span id="currentIndex"></span> of <span id="totalMedia"></span>
            </span>
        </div>
        <button class="close-btn" id="closeViewer">×</button>
    </div>
    <div class="viewer-main" id="viewerMain">
        <button class="nav-arrow left" id="prevBtn">‹</button>
        <div class="media-container" id="mediaContainer"></div>
        <button class="nav-arrow right" id="nextBtn">›</button>
    </div>
    <div class="thumbnail-strip">
        <div class="thumbnail-container" id="thumbnailContainer"></div>
    </div>
</div>
