<div id="passwordOverlay" class="passwordOverlay active" role="dialog" aria-modal="true">
    <div class="gov-password-box">
        <div class="gov-header">
            <div class="gov-emblem">🇮🇳</div>
            <div class="gov-title">
                <div class="gov-hindi">भारत सरकार</div>
                <div class="gov-eng">Government of India</div>
            </div>
        </div>
        <div class="gov-content">
            <p class="gov-note">This section is restricted. Please enter your password to continue.</p>
            <label for="passwordInput" class="gov-label">Password</label>
            <input type="password" id="passwordInput" class="gov-input" placeholder="Enter password"
                autocomplete="current-password" />
            <button class="gov-btn" id="submitBtn" onclick="unlockScreen()">Submit</button>
            <div id="errorMsg" class="gov-error"></div>
        </div>
        <div class="gov-footer">Unauthorized access is prohibited under IT Act, 2000.</div>
    </div>
</div>
